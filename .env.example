# ─── Workspaces ───────────────────────────────────────────────
# Which workspace to use when no -w flag is given.
# Workspaces are defined in .jura/<workspace>.json settings files.
JURA_DEFAULT_WORKSPACE="my-project"

# ─── Identity ─────────────────────────────────────────────────
# The assistant's name (used in system prompt and session IDs).
JURA_NAME="Jura"

# One-line identity/personality for the system prompt.
# This follows "You are {JURA_NAME}, " in the prompt sent to Claude.
JURA_IDENTITY="a fast Q&A assistant"

# ─── Model ────────────────────────────────────────────────────
# Claude model to use for answer synthesis.
# Options: sonnet, opus, haiku (or any model ID claude CLI accepts)
JURA_MODEL="sonnet"

# ─── Search Tuning ────────────────────────────────────────────
# Number of results to request from each search command.
# Two commands run in parallel, so max raw candidates = 2 * this value.
JURA_RESULTS=8

# Number of top-ranked documents to read and send to Claude as context.
JURA_READ=5

# Minimum similarity score (0.0–1.0). Results below this are discarded.
JURA_THRESHOLD=0.10

# ─── Recency Decay ───────────────────────────────────────────
# How many days before relevance halves. Documents age in buckets:
#   0 to (N-1) days  → factor 1.0
#   N to (2N-1) days → factor 0.5
#   2N to (3N-1)     → factor 0.25  ... and so on.
# The decay factor never drops below 0.01 (1%), so old but highly
# relevant documents are never fully invisible.
# Set to 0 to disable decay entirely.
JURA_DECAY_DAYS=10
