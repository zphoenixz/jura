# ── Database ──────────────────────────────────────────────────────────
# Docker Compose uses its own DATABASE_URL override (see docker-compose.yml),
# so this value only matters when running the API outside Docker.
# Format: postgresql+asyncpg://user:password@host:port/dbname
DATABASE_URL=postgresql+asyncpg://mgmt:mgmt@localhost:5433/management

# ── API keys (required for fetching) ─────────────────────────────────
# Slack User OAuth token (xoxp-... — needs channels:history, users:read, etc.)
SLACK_BOT_TOKEN=xoxp-your-slack-user-token

# Linear API key (Personal API key from Settings > API)
LINEAR_API_KEY=lin_api_your-linear-api-key

# Fireflies API key (from integrations.fireflies.ai)
FIREFLIES_API_KEY=your-fireflies-api-key

# Notion internal integration token (from notion.so/my-integrations)
NOTION_API_KEY=ntn_your-notion-api-key

# ── Slack deep links ─────────────────────────────────────────────────
# Your Slack workspace URL (for message deep links in formatted output)
SLACK_WORKSPACE_URL=https://your-workspace.slack.com

# ── Server ───────────────────────────────────────────────────────────
API_PORT=8100
LOG_LEVEL=info
